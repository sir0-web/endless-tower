# ローカル開発用のテンプレート。コピーして .env を作成すること（.env はGit管理外）
# 例: copy .env.example .env

# Supabase（publishableキーは公開前提のキー）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# 管理者キー（サーバー専用・VITE_プレフィックス禁止！）
# 本番では Vercel の Environment Variables に ADMIN_KEY として設定する。
# ローカルで admin API を使う場合は vercel dev + この変数で動く。
ADMIN_KEY=your_admin_password_here

# admin API用（サーバー専用・絶対にVITE_を付けないこと）
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx
